# Optional configuration for win11.sh
# Format: simple KEY=value lines (no command substitutions).

# Paths can be relative to WORKDIR or absolute.
# `~/...` is supported.
ISO=Win11_24H2_English_x64.iso
VIRTIO_ISO=virtio-win-0.1.271.iso

# VM options
DISK=win11.qcow2
DISK_SIZE=64G
MEMORY=8G
CPUS=4

# Minimum free space (GB) required in WORKDIR filesystem.
REQUIRED_FREE_GB=16

# AppArmor-friendly defaults.
# Consider moving WORKDIR to /var/windows.
TPM_DIR=/tmp/tpm-dir

# Networking (disabled by default; enable with --net)
TAP_IFNAME=tap0
BRIDGE_IFNAME=virbr0
